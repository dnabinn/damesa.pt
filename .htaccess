<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^$ pages/index.html [L]
  RewriteRule ^restaurante/([^/]+)/([^/]+)/?$ pages/restaurant.html?slug=$2 [L,QSA]
  RewriteRule ^reservar/([^/]+)/?$ pages/reservar.html?slug=$1 [L,QSA]
  RewriteRule ^(restaurantes|cozinhas|login|dashboard|owner-dashboard|superadmin|privacy|terms|offline)/?$ pages/$1.html [L]
  RewriteRule ^([a-zA-Z0-9_-]+\.html)$ pages/$1 [L]
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .json
  AddType text/javascript .js
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "assetlinks\.json$">
    Header set Content-Type "application/json"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>
