Options -Indexes
ErrorDocument 404 /pages/404.html

# Correct MIME types for PWA
<IfModule mod_mime.c>
  AddType application/manifest+json .json
  AddType text/javascript .js
  AddType image/png .png
</IfModule>

# Cache control — icons and SW
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType application/manifest+json "access plus 1 day"
  # Service worker must NOT be cached long-term
  <FilesMatch "sw\.js$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  # Allow TWA / browser to verify assetlinks
  <FilesMatch "assetlinks\.json$">
    Header set Content-Type "application/json"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  # Security headers
  Header always set X-Content-Type-Options "nosniff"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve existing files and directories directly (src/js, assets, sw.js, .well-known, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Root → pages/index.html
  RewriteRule ^$ pages/index.html [L]

  # Clean restaurant URLs: damesa.pt/restaurante/lisboa/lumbini
  RewriteRule ^restaurante/([^/]+)/([^/]+)/?$ pages/restaurant.html?slug=$2 [L,QSA]

  # *.html → pages/*.html (e.g. damesa.pt/restaurantes.html)
  RewriteRule ^([a-zA-Z0-9_-]+\.html)$ pages/$1 [L]
</IfModule>
